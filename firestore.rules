rules_version = '2';

// Regra simples: só permite ler/escrever quem estiver logado.
// Como só existe um usuário (você), isso é suficiente —
// não há cadastro público nem qualquer forma de acesso anônimo.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
