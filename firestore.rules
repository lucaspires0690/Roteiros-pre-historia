rules_version = '2';

// Só este e-mail consegue ler/escrever no banco de dados.
// Isso é o que de fato protege seus dados — a tela de login do app
// é só conveniência; quem garante a segurança é esta regra aqui.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'lucasserip1990@gmail.com';
    }
  }
}
